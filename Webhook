return function(title, statusText, color)
    -- ดึงค่า Config จาก getgenv() ของสคริปต์หลัก
    local config = getgenv().Config
    
    -- เช็คว่ามี Config หรือไม่ และเช็คว่าเปิดใช้งาน Webhook หรือไม่
    if not config or not config.WebhookEnabled then return end
    if not config.WebhookURL or config.WebhookURL == "" then return end

    spawn(function()
        pcall(function()
            local HttpService = game:GetService("HttpService")
            local Players = game:GetService("Players")
            local LocalPlayer = Players.LocalPlayer

            local embed = {
                ["title"] = title,
                ["description"] = statusText,
                ["type"] = "rich",
                ["color"] = color or 0x00FF00,
                ["fields"] = {
                    { ["name"] = "Player", ["value"] = LocalPlayer.Name, ["inline"] = true },
                    { ["name"] = "Game ID", ["value"] = tostring(game.PlaceId), ["inline"] = true },
                    { ["name"] = "Server JobID", ["value"] = "||" .. game.JobId .. "||", ["inline"] = false },
                },
                ["footer"] = { ["text"] = "OrbitAI Notification System" },
                ["timestamp"] = os.date("!%Y-%m-%dT%H:%M:%SZ")
            }

            local payload = HttpService:JSONEncode({
                ["content"] = "",
                ["embeds"] = {embed}
            })

            local requestFunction = syn and syn.request or http_request or request
            if requestFunction then
                requestFunction({
                    Url = config.WebhookURL,
                    Method = "POST",
                    Headers = { ["Content-Type"] = "application/json" },
                    Body = payload
                })
            end
        end)
    end)
end
